generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model VisitedCountry {
  id         String   @id @default(cuid())
  code       String   @unique // ISO 3166-1 alpha-2
  name       String   // English name
  nameZh     String   @default("") // Chinese name
  visitedAt  DateTime @default(now())
}

model VisitedPlace {
  id        String   @id @default(cuid())
  name      String
  province  String   @default("")
  adcode    String   @default("") // administrative division code
  lat       Float    @default(0)
  lng       Float    @default(0)
  level     String   @default("city") // "province" or "city"
  visitedAt DateTime @default(now())
}
